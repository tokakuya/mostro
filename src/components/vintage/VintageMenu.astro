---
import banner from '../../assets/vintage/mcbana.gif';
import { buildVintageMenuChunks } from '../../lib/vintageEpisodeGroups';
import type { MangaEpisode } from '../../lib/mangaData';
import { siteLinks } from '../../lib/siteLinks';
import VintageMenuGroup from './VintageMenuGroup.astro';

interface Props {
	episodes: MangaEpisode[];
	menuInstanceId: string;
	showSettings?: boolean;
}

const { episodes, menuInstanceId, showSettings = true } = Astro.props;
const menuChunks = buildVintageMenuChunks(episodes);
const panelId = (id: string) => `${id}-${menuInstanceId}`;

const boothLink = 'https://momotori.booth.pm/';
const seisakuLink =
	siteLinks.find((l) => l.label === '販売処')?.href ??
	'https://www.dlsite.com/home/circle/profile/=/maker_id/RG24350.html';
---

<nav class="vintage-menu" aria-label="メニュー">
	<p class="vintage-menu-intro">
		<span>
			<img class="vintage-menu-banner" src={banner.src} width={banner.width} height={banner.height} alt="" />
			<br /><br /><br />
			<a href="/"><b>Top</b></a><b><br />
			<a href={seisakuLink} target="_blank" rel="noopener noreferrer"><b>制作</b></a><b><br />
			<a href={boothLink} target="_blank" rel="noopener noreferrer"><b>BOOTH</b></a><b><br /></b></b></b>
		</span>
	</p>

	{
		menuChunks.map((chunk, chunkIndex) => (
			<>
				<div class="menu">
					{
						chunkIndex === 0 ? (
							<>
								<label for={panelId('Panel0')}>ばっくやーど数こま</label>
								<input type="checkbox" id={panelId('Panel0')} class="on-off" />
							</>
						) : null
					}
					{chunk.groups.map((group) => <VintageMenuGroup group={group} panelId={panelId} />)}
				</div>
				{
					chunk.promoAfter ? (
						<p class="vintage-menu-promo">
							<a href={chunk.promoAfter.href} target="_blank" rel="noopener noreferrer">
								<b>{chunk.promoAfter.label}</b>
							</a>
						</p>
					) : null
				}
			</>
		))
	}

	{
		showSettings ? (
			<div class="vintage-menu-settings">
				<div class="vintage-menu-settings-title">サイトの設定</div>
				<label>
					<span>ビンテージモード</span>
					<input data-vintage-toggle type="checkbox" checked />
				</label>
			</div>
		) : null
	}
</nav>
