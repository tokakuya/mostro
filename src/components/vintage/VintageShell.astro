---
import VintageMenu from './VintageMenu.astro';
import type { MangaEpisode } from '../../lib/mangaData';

interface Props {
	episodes: MangaEpisode[];
	contentVariant?: 'top' | 'viewer' | 'default';
}

const { episodes, contentVariant = 'default' } = Astro.props;

const contentClass =
	contentVariant === 'top'
		? 'vintage-content-column vintage-content-column--top'
		: contentVariant === 'viewer'
			? 'vintage-content-column vintage-content-column--viewer'
			: 'vintage-content-column';
---

<div class="site-vintage">
	<!-- Mobile header + drawer -->
	<div class="vintage-mobile-header">
		<a href="/">桃色CODE</a>
		<label for="vintage-drawer-toggle" class="vintage-mobile-menu-btn">メニュー</label>
	</div>

	<div class="vintage-mobile-drawer">
		<input type="checkbox" id="vintage-drawer-toggle" />
		<label for="vintage-drawer-toggle" class="vintage-mobile-drawer-overlay" aria-label="メニューを閉じる"></label>
		<div class="vintage-mobile-drawer-panel">
			<VintageMenu episodes={episodes} menuInstanceId="mobile" />
		</div>
	</div>

	<!-- Desktop frameset（本家 cols="10%,*" 相当・境界ドラッグでリサイズ可） -->
	<div class="vintage-frameset" data-vintage-frameset>
		<aside class="vintage-menu-column" data-vintage-menu-column>
			<VintageMenu episodes={episodes} menuInstanceId="desktop" />
		</aside>
		<div
			class="vintage-frameset-resizer"
			role="separator"
			aria-orientation="vertical"
			aria-label="メニューとコンテンツの境界をリサイズ"
			aria-controls="vintage-content"
			tabindex="0"
			data-vintage-resizer
		></div>
		<main id="vintage-content" class={contentClass}>
			<slot />
		</main>
	</div>
</div>

<script is:inline>
	(() => {
		const WIDTH_KEY = 'vintage-menu-width';
		const MIN_PX = 40;
		const frameset = document.querySelector('[data-vintage-frameset]');
		const menu = document.querySelector('[data-vintage-menu-column]');
		const resizer = document.querySelector('[data-vintage-resizer]');
		if (!(frameset instanceof HTMLElement) || !(menu instanceof HTMLElement) || !(resizer instanceof HTMLElement)) {
			return;
		}

		const maxPx = () => Math.max(MIN_PX, frameset.clientWidth - MIN_PX - resizer.offsetWidth);

		const applyWidth = (px) => {
			const clamped = Math.max(MIN_PX, Math.min(maxPx(), px));
			frameset.style.setProperty('--vintage-menu-width', `${Math.round(clamped)}px`);
			resizer.setAttribute('aria-valuenow', String(Math.round(clamped)));
			return clamped;
		};

		const currentWidth = () => menu.getBoundingClientRect().width;

		const persist = () => {
			try {
				localStorage.setItem(WIDTH_KEY, String(Math.round(currentWidth())));
			} catch {}
		};

		// 保存済み幅があれば復元。なければ本家どおり CSS の 10% を使う
		try {
			const saved = localStorage.getItem(WIDTH_KEY);
			if (saved != null) {
				const n = Number.parseFloat(saved);
				if (Number.isFinite(n) && n > 0) applyWidth(n);
			}
		} catch {}

		resizer.setAttribute('aria-valuemin', String(MIN_PX));
		resizer.setAttribute('aria-valuemax', String(maxPx()));
		resizer.setAttribute('aria-valuenow', String(Math.round(currentWidth())));

		let dragging = false;

		const onPointerMove = (event) => {
			if (!dragging) return;
			const rect = frameset.getBoundingClientRect();
			applyWidth(event.clientX - rect.left);
		};

		const onPointerUp = () => {
			if (!dragging) return;
			dragging = false;
			frameset.classList.remove('is-resizing');
			document.body.style.removeProperty('cursor');
			document.body.style.removeProperty('user-select');
			persist();
		};

		resizer.addEventListener('pointerdown', (event) => {
			if (event.button != null && event.button !== 0) return;
			dragging = true;
			frameset.classList.add('is-resizing');
			document.body.style.cursor = 'col-resize';
			document.body.style.userSelect = 'none';
			resizer.setPointerCapture?.(event.pointerId);
			event.preventDefault();
		});

		resizer.addEventListener('pointermove', onPointerMove);
		resizer.addEventListener('pointerup', onPointerUp);
		resizer.addEventListener('pointercancel', onPointerUp);
		window.addEventListener('pointerup', onPointerUp);

		resizer.addEventListener('keydown', (event) => {
			const step = event.shiftKey ? 40 : 10;
			if (event.key === 'ArrowLeft') {
				event.preventDefault();
				applyWidth(currentWidth() - step);
				persist();
			} else if (event.key === 'ArrowRight') {
				event.preventDefault();
				applyWidth(currentWidth() + step);
				persist();
			} else if (event.key === 'Home') {
				event.preventDefault();
				applyWidth(frameset.clientWidth * 0.1);
				persist();
			}
		});

		window.addEventListener('resize', () => {
			resizer.setAttribute('aria-valuemax', String(maxPx()));
			// ビューポート縮小でメニューがはみ出したらクランプ
			if (currentWidth() > maxPx()) {
				applyWidth(maxPx());
				persist();
			}
		});
	})();
</script>
