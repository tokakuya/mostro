---
import InfoSections from '../components/widget/InfoSections.astro';
import LatestEpisodeCard from '../components/widget/LatestEpisodeCard.astro';
import EpisodeList from '../components/widget/EpisodeList.astro';
import MobileFooter from '../components/widget/MobileFooter.astro';
import MobileHeader from '../components/widget/MobileHeader.astro';
import ContentColumn from '../components/widget/ContentColumn.astro';
import SiteLogo from '../components/widget/SiteLogo.astro';
import SiteFooter from '../components/widget/SiteFooter.astro';
import SiteNav from '../components/widget/SiteNav.astro';
import ThemeToggle from '../components/widget/ThemeToggle.astro';
import ThemeToggleScript from '../components/widget/ThemeToggleScript.astro';
import Layout from './Layout.astro';
import { getMangaEpisodes } from '../lib/mangaData';

interface Props {
	title?: string;
	drawerId?: string;
	siteTitle?: string;
}

const {
	title = '桃色CODE',
	drawerId = 'app-drawer',
	siteTitle = '桃色CODE',
} = Astro.props;

const episodes = getMangaEpisodes();
const latest = episodes.at(-1);

const hasLeft = Astro.slots.has('left');
const hasRight = Astro.slots.has('right');
const hasMobileFooter = Astro.slots.has('mobile-footer');
const hasMobile = Astro.slots.has('mobile');
const hasDrawer = Astro.slots.has('drawer');
---

<Layout title={title}>
	<div class="min-h-screen bg-base-100">
		<!-- Desktop: 3 columns -->
		<div class="hidden lg:block">
			<div
				class="mx-auto grid w-full max-w-6xl grid-cols-1 gap-6 p-6 lg:grid-cols-[220px_1fr_260px]"
			>
				<aside class="flex flex-col gap-6">
					{
						hasLeft ? (
							<slot name="left" />
						) : (
							<>
								<div class="flex flex-col items-center gap-2 pt-2">
									<SiteLogo siteTitle={siteTitle} />
								</div>

								<SiteNav class="p-3" />
								<InfoSections />
							</>
						)
					}
				</aside>

				<main class="flex justify-center">
					<slot />
				</main>

				<aside class="flex flex-col gap-4">
					{
						hasRight ? (
							<slot name="right" />
						) : (
							<>
								<div class="border border-base-300 bg-base-100 p-4">
									<LatestEpisodeCard
										latest={latest}
										heading="ぱっく〜と数コマ"
										labelClass="text-sm"
									/>

									<EpisodeList episodes={episodes} />
								</div>

								<ThemeToggle />
							</>
						)
					}
				</aside>
			</div>

			<SiteFooter />
		</div>

		<!-- Mobile: header + drawer -->
		<div class="lg:hidden">
			<div class="drawer drawer-end">
				<input id={drawerId} type="checkbox" class="drawer-toggle" />
				<div class="drawer-content">
					<MobileHeader drawerId={drawerId} siteTitle={siteTitle} />

					<main class="pb-10">
						<ContentColumn>
							{hasMobile ? <slot name="mobile" /> : <slot />}

							{
								hasMobileFooter ? <slot name="mobile-footer" /> : <MobileFooter />
							}
						</ContentColumn>
					</main>
				</div>

				<div class="drawer-side">
					<label for={drawerId} aria-label="close sidebar" class="drawer-overlay"></label>
					<div class="min-h-full w-80 bg-base-100 p-4">
						{
							hasDrawer ? (
								<slot name="drawer" />
							) : (
								<>
									<SiteNav class="p-2" />

									<EpisodeList
										episodes={episodes}
										summaryLabel="話数"
										showTitle={false}
										maxHeightClass="max-h-[50vh]"
										class="mt-6 border border-base-300 bg-base-100"
										summaryClass="cursor-pointer select-none px-4 py-3 text-sm font-semibold"
									/>

									<ThemeToggle class="mt-6" />
								</>
							)
						}
					</div>
				</div>
			</div>
		</div>
	</div>

	<ThemeToggleScript />
</Layout>
