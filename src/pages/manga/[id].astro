---
import Layout from '../../layouts/Layout.astro';
import { getAdjacentEpisodes, getMangaEpisodes } from '../../lib/manga';

export function getStaticPaths() {
	return getMangaEpisodes().map((episode) => ({
		params: { id: String(episode.id) },
		props: { episode },
	}));
}

const { episode } = Astro.props;
const { prev, next } = getAdjacentEpisodes(episode.id);
---

<Layout title={`第${episode.id}話`}>
	<div class="min-h-screen bg-base-300">
		<header class="navbar sticky top-0 z-10 bg-base-100 shadow-sm">
			<div class="navbar-start">
				<a href="/" class="btn btn-ghost btn-sm">一覧</a>
			</div>
			<div class="navbar-center">
				<h1 class="text-lg font-bold">第{episode.id}話</h1>
			</div>
			<div class="navbar-end gap-1">
				{
					prev ? (
						<a href={`/${prev.id}view`} class="btn btn-ghost btn-sm">
							← 第{prev.id}話
						</a>
					) : (
						<span class="btn btn-ghost btn-sm btn-disabled">← 前話</span>
					)
				}
				{
					next ? (
						<a href={`/${next.id}view`} class="btn btn-ghost btn-sm">
							第{next.id}話 →
						</a>
					) : (
						<span class="btn btn-ghost btn-sm btn-disabled">次話 →</span>
					)
				}
			</div>
		</header>

		<main class="mx-auto flex w-full max-w-3xl flex-col">
			{
				episode.pages.map((page, index) => (
					<img
						src={page.image.src}
						width={page.image.width}
						height={page.image.height}
						alt={`第${episode.id}話 ${index + 1}ページ目`}
						class="h-auto w-full"
						loading={index < 2 ? 'eager' : 'lazy'}
						decoding="async"
					/>
				))
			}
		</main>

		<footer class="flex justify-center gap-4 py-8">
			{
				prev ? (
					<a href={`/${prev.id}view`} class="btn btn-outline">
						← 第{prev.id}話
					</a>
				) : null
			}
			{
				next ? (
					<a href={`/${next.id}view`} class="btn btn-primary">
						第{next.id}話 →
					</a>
				) : null
			}
		</footer>
	</div>
</Layout>
